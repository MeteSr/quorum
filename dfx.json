{
  "version": 1,
  "defaults": {
    "build": {
      "packtool": "mops sources"
    }
  },
  "canisters": {
    "members": {
      "type": "motoko",
      "main": "backend/members/main.mo"
    },
    "governance": {
      "type": "motoko",
      "main": "backend/governance/main.mo"
    },
    "treasury": {
      "type": "motoko",
      "main": "backend/treasury/main.mo"
    },
    "documents": {
      "type": "motoko",
      "main": "backend/documents/main.mo"
    },
    "announcements": {
      "type": "motoko",
      "main": "backend/announcements/main.mo"
    },
    "violations": {
      "type": "motoko",
      "main": "backend/violations/main.mo"
    },
    "frontend": {
      "type": "assets",
      "source": ["frontend/dist"],
      "dependencies": [
        "members",
        "governance",
        "treasury",
        "documents",
        "announcements",
        "violations"
      ]
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:8000",
      "type": "ephemeral"
    }
  }
}
